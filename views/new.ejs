<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Notes</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Create Note</h1>
    <div class="form-card">
    <form action="/notes" method="post">
       Title : &nbsp; &nbsp; <input type="text" name="title" required> <br><br>
        Content : <textarea name="content" rows="10" cols="20" required></textarea><br><br>
        <button>Create</button>
    </form>
    </div>
</body>
</html>